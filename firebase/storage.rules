rules_version = '2';

// Règles Firebase Storage — souanpt.hub V2
// Uniquement les PETITES ressources : avatars, logos, couvertures optimisées, miniatures.
// Les gros fichiers (ZIP, PSD, vidéos) restent hébergés en externe (Drive, WeTransfer,
// GitHub Releases…) et ne sont référencés que par un lien dans Firestore.

service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read: if true;  // avatars/logos/couvertures = publics
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024          // 5 Mo max
                   && request.resource.contentType.matches('image/.*'); // images uniquement
    }

    // ── Références déposées par un CLIENT SANS COMPTE via le formulaire ──
    // Chemin isolé requests/<token>/<fileId>/<nom>. Écriture anonyme autorisée
    // mais fortement bornée : 20 Mo, et JAMAIS de contenu exécutable (le type
    // MIME de ces formats est refusé). Lecture publique pour que le créateur et
    // le client revoient la référence via son URL de téléchargement.
    match /requests/{token}/{fileId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 20 * 1024 * 1024
                   && !request.resource.contentType.matches('application/x-msdownload')
                   && !request.resource.contentType.matches('application/x-executable')
                   && !request.resource.contentType.matches('application/vnd.android.package-archive')
                   && !request.resource.contentType.matches('application/x-sh')
                   && !request.resource.contentType.matches('text/javascript');
    }
  }
}
