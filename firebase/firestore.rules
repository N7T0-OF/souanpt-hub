rules_version = '2';

// Règles de sécurité Firestore — souanpt.hub V2
// Principe : chaque document appartient à un UID. Personne ne peut lire/écrire
// les données d'un autre. Les profils, portails et avis publiés sont lisibles
// publiquement (pour /@pseudo et les liens de portail sans compte), mais seuls
// leurs propriétaires peuvent les modifier.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function owns(uid)  { return signedIn() && request.auth.uid == uid; }
    function isOwner()  { return signedIn() && request.auth.uid == resource.data.owner; }
    function creatingSelf() { return signedIn() && request.resource.data.owner == request.auth.uid; }

    // Profil public (portfolio /@pseudo) — lecture ouverte, écriture propriétaire
    match /users/{uid} {
      allow read: if true;
      allow write: if owns(uid);

      // Sous-collections privées de l'utilisateur
      match /{sub}/{docId} {
        allow read, write: if owns(uid);
      }
    }

    // Portails clients — lisibles par tous (lien privé sans compte), écrits par le propriétaire
    match /portals/{id} {
      allow read: if true;
      allow create: if creatingSelf();
      allow update, delete: if isOwner();
    }

    // Avis publiés — lisibles par tous, créés par un visiteur (validés ensuite), gérés par le propriétaire
    match /reviews/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['owner','author','text'])
                    && request.resource.data.status == 'pending';
      allow update, delete: if isOwner();
    }

    // ── Estimations partagées par lien, consultées SANS compte ──
    // ⚠ Ce document est PUBLIC en lecture : il ne doit contenir que ce que le
    // client a le droit de voir (lignes, total, délai, expiration). Le prix
    // plancher, le taux horaire et la marge restent dans users/{uid}/data,
    // qui n'est lisible que par son propriétaire.
    match /estimates/{code} {
      allow read: if true;
      allow create: if creatingSelf();
      allow update, delete: if isOwner();

      // Contre-offres. Le client n'a pas de compte — c'est tout l'intérêt du
      // lien — donc la création est ouverte, mais la FORME est verrouillée :
      // rien d'autre que ces champs ne peut être écrit, et le statut initial
      // est imposé pour qu'une offre ne puisse pas s'auto-accepter.
      match /offers/{offerId} {
        allow read: if true;
        // `kind` distingue une contre-offre ('counter') d'une acceptation
        // ('acceptance'). Une acceptation reste status:'pending' : c'est un
        // ENGAGEMENT DU CLIENT, que le créateur confirme ensuite côté tableau
        // de bord (modèle à deux parties). Le client ne peut donc jamais
        // marquer une estimation acceptée tout seul.
        allow create: if
             request.resource.data.keys().hasOnly(['author','amount','discountPercent','message','status','createdAt','kind'])
          && request.resource.data.status == 'pending'
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.amount < 1000000
          && (!('kind' in request.resource.data)
              || request.resource.data.kind in ['counter','acceptance'])
          && (!('message' in request.resource.data)
              || (request.resource.data.message is string && request.resource.data.message.size() <= 600))
          && (
               request.resource.data.author == 'client'
               || (signedIn()
                   && get(/databases/$(database)/documents/estimates/$(code)).data.owner == request.auth.uid
                   && request.resource.data.author == 'creator')
             );
        // Seul le créateur de l'estimation peut accepter, refuser ou effacer.
        allow update, delete: if signedIn()
          && get(/databases/$(database)/documents/estimates/$(code)).data.owner == request.auth.uid;
      }
    }

    // ── Formulaires de demande, remplis par le client SANS compte ──
    // Le créateur crée le document (vide, status:'open'). Le client public ne
    // peut QUE compléter SA demande tant qu'elle est ouverte, et rien d'autre :
    // il ne peut ni changer le propriétaire, ni rouvrir une demande traitée,
    // ni écrire un prix ou un statut interne (ces champs vivent ailleurs).
    match /requests/{token} {
      allow read: if true;
      allow create: if creatingSelf();
      allow delete: if isOwner();
      // Le créateur (connecté, propriétaire) : tout.
      // Le client (anonyme) : seulement passer 'open' → 'submitted' et remplir
      // les champs autorisés, jamais toucher owner/creatorName/status déjà figé.
      allow update: if isOwner()
        || (
             resource.data.status == 'open'
          && request.resource.data.owner == resource.data.owner
          && request.resource.data.status == 'submitted'
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status','submittedAt','contact','service','answers','description','budget','deadline','links','attachments'])
        );

      // ── Questions complémentaires posées par le créateur ──
      // Le client (anonyme) ne peut QUE répondre à une question 'pending' de
      // SON token, et seulement les champs de réponse. Il ne peut ni modifier
      // la question, ni son type, ni la rouvrir, ni toucher un autre dossier.
      match /questions/{qid} {
        allow read: if true;
        allow create, delete: if signedIn()
          && get(/databases/$(database)/documents/requests/$(token)).data.owner == request.auth.uid;
        allow update: if
             // Le créateur : tout (relance, annulation, verrouillage…).
             (signedIn() && get(/databases/$(database)/documents/requests/$(token)).data.owner == request.auth.uid)
             // Le client : répondre à une question en attente et non verrouillée.
          || (
               resource.data.status == 'pending'
            && resource.data.locked != true
            && request.resource.data.status == 'answered'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['answer','answeredAt','status'])
             )
             // Le client : signaler qu'il a vu la question (accusé de lecture).
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenAt']));
      }
    }

    // Collections privées scopées par owner
    match /{col}/{id} {
      allow read:   if isOwner();
      allow create: if creatingSelf();
      allow update, delete: if isOwner();
    }
  }
}
