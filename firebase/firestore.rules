rules_version = '2';

// Règles de sécurité Firestore — souanpt.hub V2
// Principe : chaque document appartient à un UID. Personne ne peut lire/écrire
// les données d'un autre. Les profils, portails et avis publiés sont lisibles
// publiquement (pour /@pseudo et les liens de portail sans compte), mais seuls
// leurs propriétaires peuvent les modifier.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function owns(uid)  { return signedIn() && request.auth.uid == uid; }
    function isOwner()  { return signedIn() && request.auth.uid == resource.data.owner; }
    function creatingSelf() { return signedIn() && request.resource.data.owner == request.auth.uid; }

    // Profil public (portfolio /@pseudo) — lecture ouverte, écriture propriétaire
    match /users/{uid} {
      allow read: if true;
      allow write: if owns(uid);

      // Sous-collections privées de l'utilisateur
      match /{sub}/{docId} {
        allow read, write: if owns(uid);
      }
    }

    // Portails clients — lisibles par tous (lien privé sans compte), écrits par le propriétaire
    match /portals/{id} {
      allow read: if true;
      allow create: if creatingSelf();
      allow update, delete: if isOwner();
    }

    // Avis publiés — lisibles par tous, créés par un visiteur (validés ensuite), gérés par le propriétaire
    match /reviews/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['owner','author','text'])
                    && request.resource.data.status == 'pending';
      allow update, delete: if isOwner();
    }

    // ── Estimations partagées par lien, consultées SANS compte ──
    // ⚠ Ce document est PUBLIC en lecture : il ne doit contenir que ce que le
    // client a le droit de voir (lignes, total, délai, expiration). Le prix
    // plancher, le taux horaire et la marge restent dans users/{uid}/data,
    // qui n'est lisible que par son propriétaire.
    match /estimates/{code} {
      allow read: if true;
      allow create: if creatingSelf();
      allow update, delete: if isOwner();

      // Contre-offres. Le client n'a pas de compte — c'est tout l'intérêt du
      // lien — donc la création est ouverte, mais la FORME est verrouillée :
      // rien d'autre que ces champs ne peut être écrit, et le statut initial
      // est imposé pour qu'une offre ne puisse pas s'auto-accepter.
      match /offers/{offerId} {
        allow read: if true;
        allow create: if
             request.resource.data.keys().hasOnly(['author','amount','discountPercent','message','status','createdAt'])
          && request.resource.data.status == 'pending'
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.amount < 1000000
          && (!('message' in request.resource.data)
              || (request.resource.data.message is string && request.resource.data.message.size() <= 600))
          && (
               request.resource.data.author == 'client'
               || (signedIn()
                   && get(/databases/$(database)/documents/estimates/$(code)).data.owner == request.auth.uid
                   && request.resource.data.author == 'creator')
             );
        // Seul le créateur de l'estimation peut accepter, refuser ou effacer.
        allow update, delete: if signedIn()
          && get(/databases/$(database)/documents/estimates/$(code)).data.owner == request.auth.uid;
      }
    }

    // Collections privées scopées par owner
    match /{col}/{id} {
      allow read:   if isOwner();
      allow create: if creatingSelf();
      allow update, delete: if isOwner();
    }
  }
}
